# =============================================================================
# INVITRACK — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control. This file (.env.example) is safe to commit.
# All values here are placeholders. See the inline comments for how to obtain each.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------

NODE_ENV=development
# Values: development | production | test
# Set to "production" in your AWS EC2 environment and "test" in CI/CD pipelines.
# No external service required — set manually.

PORT=5000
# The port your Express server listens on locally.
# In production on EC2, this is typically 5000 or 8080 (behind an Nginx reverse proxy or exposed directly).
# No external service required — set manually.


# -----------------------------------------------------------------------------
# DATABASE — PostgreSQL
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/invitrack_db
# Full PostgreSQL connection string used by your Node.js app (e.g. via pg or Knex).
#
# Prerequisites:
#   1. Install PostgreSQL locally (https://www.postgresql.org/download/).
#   2. Open psql or pgAdmin and run:
#        CREATE USER your_db_user WITH PASSWORD 'your_db_password';
#        CREATE DATABASE invitrack_db OWNER your_db_user;
#   3. Run your schema migration scripts (from /database-schema.md or your migrations folder)
#      to initialise all six module schemas (auth, users, inventory, bookings, audit, analytics).
#   4. Replace the placeholders above with the actual user, password, host, port, and DB name.
#
# For production (AWS EC2):
#   - Your DB runs on the same EC2 instance (co-located to stay within free tier).
#   - Use 127.0.0.1 as the host instead of localhost to avoid Unix socket issues.
#   - Example: postgresql://invitrack_prod:StrongPass123@127.0.0.1:5432/invitrack_prod_db
#
# Important notes:
#   - Never use your PostgreSQL superuser (postgres) for the app connection.
#   - Grant only the minimum required privileges to your app user.

DATABASE_POOL_MIN=2 #redundant for prisma
DATABASE_POOL_MAX=10 #redundant for prisma
# Connection pool limits for your PostgreSQL client (e.g. Knex, pg-pool).
# These are sane defaults. Increase max carefully — each connection consumes DB memory.
# No external service required — set manually.


# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379
# Connection string for your Redis instance, used for:
#   - Distributed advisory locks (booking conflict prevention)
#   - Session/token caching
#
# Prerequisites:
#   1. Install Redis locally:
#        macOS:   brew install redis && brew services start redis
#        Ubuntu:  sudo apt install redis-server && sudo systemctl start redis
#   2. Verify it's running: redis-cli ping  →  should return PONG
#
# For production (AWS EC2):
#   - Redis runs on the same EC2 instance (free tier constraint).
#   - Bind Redis to 127.0.0.1 only (never expose it publicly).
#   - Example: redis://127.0.0.1:6379
#
# Important notes:
#   - If you add Redis AUTH in production, the URL becomes:
#     redis://:your_redis_password@127.0.0.1:6379


# -----------------------------------------------------------------------------
# JWT (JSON Web Tokens)
# -----------------------------------------------------------------------------

JWT_ACCESS_SECRET=replace_with_a_long_random_string_at_least_64_chars
# Secret key used to sign and verify JWT access tokens.
#
# How to generate:
#   Run in your terminal:
#     node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   Copy the output and paste it here.
#
# Important notes:
#   - Must be at least 64 characters for HS256. Use 128 chars for extra safety.
#   - Access tokens should be short-lived (see JWT_ACCESS_EXPIRES_IN below).
#   - Never reuse this value across environments.

JWT_REFRESH_SECRET=replace_with_a_different_long_random_string_at_least_64_chars
# Secret key used to sign and verify JWT refresh tokens.
#
# How to generate: same as JWT_ACCESS_SECRET — generate a separate, distinct value.
#
# Important notes:
#   - Must be different from JWT_ACCESS_SECRET.
#   - Refresh tokens are long-lived, so this secret must be kept very safe.
#   - Rotating this secret invalidates all existing refresh tokens (all users get logged out).

JWT_ACCESS_EXPIRES_IN=15m
# How long an access token remains valid. Short-lived by design.
# Common values: 15m | 30m | 1h
# No external service required — set manually.

JWT_REFRESH_EXPIRES_IN=7d
# How long a refresh token remains valid. Long-lived.
# Common values: 7d | 14d | 30d
# No external service required — set manually.


# -----------------------------------------------------------------------------
# SESSION / COOKIE
# -----------------------------------------------------------------------------

COOKIE_SECRET=replace_with_another_long_random_string_at_least_32_chars
# Secret used to sign cookies (e.g. via cookie-parser or express-session).
#
# How to generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Important notes:
#   - Must be distinct from your JWT secrets.
#   - Rotating this value invalidates all existing signed cookies.

SESSION_EXPIRES_IN=86400000
# Session expiry in milliseconds. 86400000 = 24 hours.
# Adjust to match your refresh token lifetime if using session-based refresh tracking.
# No external service required — set manually.


# -----------------------------------------------------------------------------
# CORS / FRONTEND
# -----------------------------------------------------------------------------

FRONTEND_URL=http://localhost:5173
# The URL of your React frontend. Used by Express CORS config to whitelist the origin.
#
# Local development:
#   Vite's default dev server runs on http://localhost:5173.
#   If you changed the port, update this accordingly.
#
# Production (AWS S3 static hosting):
#   1. Create an S3 bucket with static website hosting enabled.
#   2. Upload your React build output (npm run build) to the bucket.
#   3. Note the S3 static website endpoint:
#      http://your-bucket-name.s3-website-us-east-1.amazonaws.com
#   4. (Optional) Set up CloudFront in front of S3 for HTTPS — gives you a *.cloudfront.net URL.
#   5. Replace this value with your S3 or CloudFront URL.
#
# Important notes:
#   - Do not include a trailing slash.
#   - In production, CORS should only allow this exact origin.

API_BASE_URL=http://localhost:5000
# The base URL of this Express API. Used by the frontend to make requests.
# In production, this will be your EC2 public IP or domain:
#   http://your-ec2-public-ip:5000
#   or https://api.yourdomain.com if you have a domain + SSL configured.
# No external service required — set manually.


# -----------------------------------------------------------------------------
# OAUTH — Google
# -----------------------------------------------------------------------------

GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
# The client ID for Google OAuth 2.0.
#
# Prerequisites:
#   - A Google account.
#
# How to obtain:
#   1. Go to https://console.cloud.google.com/
#   2. Create a new project (e.g. "Invitrack").
#   3. Navigate to APIs & Services → OAuth consent screen.
#      - Choose "External" user type.
#      - Fill in app name, support email, and developer email. Save.
#   4. Navigate to APIs & Services → Credentials.
#   5. Click "+ Create Credentials" → "OAuth client ID".
#   6. Choose application type: "Web application".
#   7. Under "Authorised redirect URIs", add:
#        http://localhost:5000/api/auth/google/callback   (development)
#        https://your-ec2-or-domain/api/auth/google/callback   (production — add later)
#   8. Click Create. Copy the Client ID shown.
#
# Important notes:
#   - The redirect URI in this config must exactly match what you registered in step 7.
#   - While the OAuth consent screen is in "Testing" mode, only whitelisted Google accounts can log in.
#   - To allow any Google user, you must publish the app (requires Google verification for sensitive scopes).

GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# The client secret for Google OAuth 2.0.
#
# How to obtain:
#   From the same Credentials page where you got GOOGLE_CLIENT_ID.
#   Click your OAuth client → copy the "Client secret" value.
#
# Important notes:
#   - Never expose this in frontend code or commit it to git.
#   - If compromised, rotate it immediately from the Google Cloud Console.

GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
# The URI Google redirects to after the user authenticates.
# Must exactly match one of the "Authorised redirect URIs" you registered in Google Cloud Console.
#
# Production value: https://your-ec2-or-domain/api/auth/google/callback
# Remember to add the production URI in Google Cloud Console before deploying.


# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

RATE_LIMIT_WINDOW_MS=900000
# Time window for rate limiting in milliseconds. 900000 = 15 minutes.
# No external service required — set manually.

RATE_LIMIT_MAX_REQUESTS=100
# Max number of requests allowed per IP within the window above.
# Tune based on expected traffic. Tighten for auth endpoints specifically.
# No external service required — set manually.


# -----------------------------------------------------------------------------
# BCRYPT
# -----------------------------------------------------------------------------

BCRYPT_SALT_ROUNDS=12
# Cost factor for bcrypt password hashing. Higher = slower = more secure.
# 12 is a solid default for 2024+ hardware. Range: 10 (fast) to 14 (slow).
# No external service required — set manually.
#
# Important note:
#   - Every increase of 1 roughly doubles the hashing time.
#   - Do not go below 10 in production.


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------

LOG_LEVEL=info
# Controls verbosity of your logger (e.g. Winston, Pino).
# Values: error | warn | info | http | debug
# Use "debug" locally, "info" or "warn" in production.
# No external service required — set manually.


# -----------------------------------------------------------------------------
# AWS (Production only)
# -----------------------------------------------------------------------------

AWS_REGION=us-east-1
# The AWS region where your EC2 instance and S3 bucket live.
# Keep both in the same region to minimise latency and data transfer costs.
#
# How to determine:
#   When you create your EC2 instance or S3 bucket in the AWS Console,
#   select the region from the top-right dropdown. Note it down and use it here.
#   Common free-tier regions: us-east-1 (N. Virginia), us-west-2 (Oregon), eu-west-1 (Ireland).

AWS_S3_BUCKET_NAME=your-invitrack-frontend-bucket
# The name of your S3 bucket used to host the React frontend build.
#
# Prerequisites:
#   - An AWS account (https://aws.amazon.com/free/ — free tier is sufficient).
#
# How to obtain:
#   1. Sign in to the AWS Console → go to S3.
#   2. Click "Create bucket".
#   3. Choose a globally unique name (e.g. invitrack-frontend-yourname).
#   4. Select your region (must match AWS_REGION above).
#   5. Under "Block Public Access settings", uncheck "Block all public access" (required for static hosting).
#   6. Enable "Static website hosting" under the bucket's Properties tab.
#   7. Set the index document to "index.html" and error document to "index.html" (for React SPA routing).
#   8. Add a bucket policy to allow public reads (see AWS docs: S3 static website policy).
#   9. Paste the bucket name here.

AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS IAM access key ID used by the backend to interact with AWS services (e.g. S3 uploads).
#
# Prerequisites:
#   - An AWS account.
#
# How to obtain:
#   1. Go to AWS Console → IAM → Users.
#   2. Create a new IAM user (e.g. "invitrack-app-user"). Do NOT use your root account.
#   3. Attach a policy granting only the permissions your app needs
#      (e.g. AmazonS3FullAccess scoped to your bucket, or a custom least-privilege policy).
#   4. Go to the user → Security credentials → Create access key.
#   5. Choose "Application running outside AWS".
#   6. Copy the Access Key ID and Secret Access Key immediately — the secret is shown only once.
#
# Important notes:
#   - Never commit these to git. If leaked, deactivate and rotate immediately from IAM.
#   - Scope IAM permissions to the minimum your app actually needs.

AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS IAM secret access key (paired with AWS_ACCESS_KEY_ID above).
# Obtained in the same step as AWS_ACCESS_KEY_ID (step 6 above).
# Shown only once at creation — store it immediately.
